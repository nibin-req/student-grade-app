@model Crud_App.Models.Subject

@if (!ViewData.ModelState.IsValid)
{
    foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
    {
        <div style="color:red;">
            @error.ErrorMessage
        </div>
    }
}
<h2>Add Subject</h2>

<form method="post">
    <label>Name</label>
    <input type="text" name="SubjectName" />

    <button type="submit">Save</button>
</form>